# Supabase (Dashboard → Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable key (sb_publishable_...), or the legacy anon key on older projects
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Server-only secrets (no NEXT_PUBLIC_ prefix — never exposed to the browser)
# Secret key (sb_secret_...), or the legacy service_role key on older projects
SUPABASE_SECRET_KEY=sb_secret_...

# Site Gemini key. Powers multimodal sticker search (gemini-embedding-2).
# Embedding search only — image generation is strictly BYOK.
# If unset, search falls back to literal matching.
GEMINI_API_KEY=your-gemini-api-key
